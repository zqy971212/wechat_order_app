page {
  min-height: 100vh;
  background: #fff7f0;
  color: #302721;
  font-family: -apple-system, BlinkMacSystemFont, "Helvetica Neue", Helvetica, Arial, sans-serif;
}

view,
scroll-view,
text,
input,
button,
image {
  box-sizing: border-box;
}

button {
  padding: 0;
  margin: 0;
  background: transparent;
  line-height: 1;
}

button::after {
  border: none;
}
